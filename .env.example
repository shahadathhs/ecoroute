# DOCKER
PACKAGE_NAME=ecoroute
DOCKER_REGISTRY=shahadathhs

# Application
APP_NAME=EcoRoute Atlas
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# Server
PORT=8000

# Database
# For local development: use localhost (PostgreSQL & Qdrant should be running locally or via Docker)
# For Docker: compose.yaml automatically overrides these to point to Docker services
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecoroute

# Vector Database (Qdrant)
# For local development: use localhost (Qdrant should be running locally or via Docker)
# For Docker: compose.yaml automatically overrides QDRANT_HOST to point to Docker service
QDRANT_HOST=localhost
QDRANT_PORT=6343
QDRANT_COLLECTION=atlas_intelligence

# Security
SECRET_KEY=your-secret-key-change-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
